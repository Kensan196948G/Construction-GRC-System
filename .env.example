# Construction-GRC-System 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_SETTINGS_MODULE=grc.settings.development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgresql://grc_admin:grc_password@localhost:5432/grc_db
POSTGRES_DB=grc_db
POSTGRES_USER=grc_admin
POSTGRES_PASSWORD=grc_password

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:3000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_HOURS=1
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
