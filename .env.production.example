# Construction-GRC-System 本番環境変数テンプレート
# このファイルを .env.production にコピーして値を設定してください
# cp .env.production.example .env.production

# Django
DJANGO_SECRET_KEY=
DJANGO_SETTINGS_MODULE=grc.settings.production
DEBUG=False
ALLOWED_HOSTS=your-domain.example.com

# Database (PostgreSQL)
POSTGRES_DB=grc_db
POSTGRES_USER=grc_admin
POSTGRES_PASSWORD=
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ORIGINS=https://your-domain.example.com

# JWT
JWT_ACCESS_TOKEN_LIFETIME_HOURS=1
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Gunicorn
GUNICORN_WORKERS=4

# Celery
CELERY_CONCURRENCY=4

# Email (SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@your-domain.example.com

# Logging
LOG_LEVEL=WARNING
